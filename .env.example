# OpenAI-compatible text model used by the extraction agents.
LLM_API_BASE=https://api.opensii.ai
LLM_API_KEY=
LLM_MODEL=gzy/claude-4.6-sonnet
LLM_REVIEW_MODEL=
LLM_USE_BEARER_AUTH=true

# Optional dedicated vision model settings. If the keys are empty, the agent
# falls back to LLM_API_KEY and LLM_API_BASE.
VLM_API_BASE=
VLM_API_KEY=
VLM_MODEL=gzy/gemini-3.1-pro-thinking

SEQUENCE_VLM_API_BASE=
SEQUENCE_VLM_API_KEY=
SEQUENCE_VLM_MODEL=gzy/gemini-3.1-pro-thinking

# Optional direct-PDF extraction helper. Defaults fall back to LLM_*.
PDF_EXTRACT_API_BASE=
PDF_EXTRACT_API_KEY=
PDF_EXTRACT_MODEL=

# Benchmark LLM-as-judge settings. Defaults fall back to LLM_* when unset.
BENCHMARK_API_KEY=
BENCHMARK_BASE_URL=
BENCHMARK_MODEL=gzy/claude-4.6-sonnet

# Optional external APIs.
NCBI_EMAIL=
NCBI_API_KEY=
MINERU_API_TOKEN=
MINERU_API_KEY=
MINERU_API_BASE_URL=
MINERU_BACKEND=official-api
MINERU_SELF_HOSTED_URL=
MINERU_SELF_HOSTED_API_TOKEN=
MINERU_SELF_HOSTED_MODEL=mineru
