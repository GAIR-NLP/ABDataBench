{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Antibody Sequence Extraction Schema v3",
    "description": "每个抗体实体的结构化元数据 JSON Schema。22 评分字段对齐评估系统 v3。",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "Master_ID",
            "Antibody_Name"
        ],
        "properties": {
            "Master_ID": {
                "type": "integer",
                "description": "从 1 开始的自增唯一标识符"
            },
            "Antibody_Name": {
                "type": "object",
                "required": ["value", "quote"],
                "properties": {
                    "value": { "type": "string", "description": "抗体名称" },
                    "quote": { "type": ["string", "null"], "description": "原文引用证明" }
                }
            },
            "Antibody_Type": {
                "type": "object",
                "required": ["value", "quote"],
                "properties": {
                    "value": { "type": ["string", "null"], "description": "必须写明具体亚型: IgG1, IgG4, VHH, scFv, Fab 等。不能只写'单克隆抗体'。若亚型不明确，写 'Monoclonal IgG (subtype not specified)'" },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Antibody_Isotype": {
                "type": "object",
                "required": ["value", "quote"],
                "properties": {
                    "value": { "type": ["string", "null"], "description": "抗体亚型，如 Human IgG1, Mouse IgG2a, IgM 等" },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "source": {
                "type": "object",
                "required": ["value", "quote"],
                "properties": {
                    "value": { "type": ["string", "null"], "description": "human / murine / camel / humanized / chimeric / engineered 等" },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Target_Name": {
                "type": "object",
                "required": ["value", "quote"],
                "properties": {
                    "value": { "type": ["string", "null"], "description": "靶点/抗原名称，必须包含具体变体信息。如 'SARS-CoV-2 Spike RBD (BA.4/5)'" },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Target_Type": {
                "type": "object",
                "required": ["value", "quote"],
                "properties": {
                    "value": { "type": ["string", "null"], "description": "如 Viral surface glycoprotein, 受体, 细胞因子等" },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Cross_Reactivity": {
                "type": "object",
                "required": ["value", "quote"],
                "properties": {
                    "value": { "type": ["string", "null"], "description": "交叉反应物种或变异株，如 Cynomolgus, Mouse, SARS-CoV-1 cross-reactive" },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Epitope": {
                "type": "object",
                "required": ["value", "quote"],
                "properties": {
                    "value": { "type": ["string", "null"], "description": "表位简述，含具体残基信息（如有），如 'RBD (11 residues: T345,R346...)'" },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Experiment": {
                "type": "object",
                "description": "注意：字段名是 Experiment（不是 Experiment_Method）",
                "properties": {
                    "value": { "type": ["string", "null"], "description": "实验方法列表，用逗号分隔。如 'Beacon, ELISA, SPR, Pseudovirus neutralization'" },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Binding_Kinetics_KD": {
                "type": "object",
                "properties": {
                    "value": { "type": ["string", "null"], "description": "解离常数 KD，如 '6.91 nM', '45 pM'。必须给出数值+单位" },
                    "pointer": { "type": ["string", "null"], "description": "数据所在图表位置，如 'Table 2'" },
                    "action": { "type": ["string", "null"], "enum": ["Script Extract", null] },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Binding_Kinetics_kon": {
                "type": "object",
                "properties": {
                    "value": { "type": ["string", "null"], "description": "结合速率常数 kon (ka)，如 '1.74 × 10^7 1/Ms'" },
                    "pointer": { "type": ["string", "null"] },
                    "action": { "type": ["string", "null"], "enum": ["Script Extract", null] },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Binding_Kinetics_koff": {
                "type": "object",
                "properties": {
                    "value": { "type": ["string", "null"], "description": "解离速率常数 koff (kd)，如 '2.51 × 10^(-4) 1/s'" },
                    "pointer": { "type": ["string", "null"] },
                    "action": { "type": ["string", "null"], "enum": ["Script Extract", null] },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Binding_EC50": {
                "type": "object",
                "properties": {
                    "value": { "type": ["string", "null"], "description": "半数有效浓度 EC50，如 '0.5 nM', '0.04 ug/mL'" },
                    "pointer": { "type": ["string", "null"] },
                    "action": { "type": ["string", "null"], "enum": ["Script Extract", null] },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Mechanism_of_Action": {
                "type": "object",
                "required": ["value", "quote"],
                "properties": {
                    "value": { "type": ["string", "null"], "description": "作用机制描述，如 Neutralization, ADCC, steric hindrance, spike crosslinking 等" },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Quantitative_Metric": {
                "type": "object",
                "properties": {
                    "value": { "type": ["string", "null"], "description": "量化指标，如 'IC50 = 0.05 µg/mL', 'NT50 = 1:2048'" },
                    "pointer": { "type": ["string", "null"] },
                    "action": { "type": ["string", "null"], "enum": ["Script Extract", null] },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Structure": {
                "type": "object",
                "properties": {
                    "value": { "type": ["string", "null"], "description": "结构信息：PDB ID (如 6WPT), Cryo-EM 分辨率, X-ray crystal structure 等" },
                    "action": { "type": ["string", "null"], "enum": ["API Fetch", null] },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "CDRH3_Sequence": {
                "type": "object",
                "properties": {
                    "value": { "type": ["string", "null"], "description": "CDRH3 氨基酸序列。注意 OCR 容易丢失 I 字符" },
                    "pointer": { "type": ["string", "null"] },
                    "action": { "type": ["string", "null"], "enum": ["Script Extract", "API Fetch", null] },
                    "confidence": { "type": ["string", "null"], "enum": ["Level 1", "Level 2", "Level 3", null] },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "vh_sequence_aa": {
                "type": "object",
                "properties": {
                    "value": { "type": ["string", "null"], "description": "VH 完整氨基酸序列（可变区），如无则为 null。若文中给出 GenBank accession，可保留 accession pointer 并通过 API Fetch 回填 value" },
                    "pointer": { "type": ["string", "null"] },
                    "action": { "type": ["string", "null"], "enum": ["Script Extract", "API Fetch", null] },
                    "germline": { "type": ["string", "null"], "description": "Germline 信息，格式必须含 identity%。如 'VH4-4/JH3/DH1-26(93%)'" },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "vl_sequence_aa": {
                "type": "object",
                "properties": {
                    "value": { "type": ["string", "null"], "description": "VL 完整氨基酸序列（可变区），如无则为 null。若文中给出 GenBank accession，可保留 accession pointer 并通过 API Fetch 回填 value" },
                    "pointer": { "type": ["string", "null"] },
                    "action": { "type": ["string", "null"], "enum": ["Script Extract", "API Fetch", null] },
                    "germline": { "type": ["string", "null"], "description": "Germline 信息，格式必须含 identity%。如 'VK1-5/JK1(94.3%)'" },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Thermal_Stability_Tm": {
                "type": "object",
                "properties": {
                    "value": { "type": ["string", "null"], "description": "热稳定性 Tm 值，如 '65.3°C'" },
                    "pointer": { "type": ["string", "null"] },
                    "action": { "type": ["string", "null"], "enum": ["Script Extract", null] },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "In_Vivo_Half_Life": {
                "type": "object",
                "required": ["value", "quote"],
                "properties": {
                    "value": { "type": ["string", "null"], "description": "体内半衰期，必须给出具体数值+单位（如 '586h', '21 days'），而非'延长的半衰期'" },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "In_Vivo_Efficacy": {
                "type": "object",
                "properties": {
                    "value": { "type": ["string", "null"], "description": "动物模型疗效简述，如 '100% survival at 10 mg/kg', 'TGI=75%'" },
                    "pointer": { "type": ["string", "null"] },
                    "action": { "type": ["string", "null"], "enum": ["Script Extract", null] },
                    "quote": { "type": ["string", "null"] }
                }
            },
            "Reference_Source": {
                "type": "object",
                "required": ["value", "quote"],
                "properties": {
                    "value": { "type": ["string", "null"], "description": "文献来源，格式: '期刊名 年份 (第一作者 et al.)'" },
                    "quote": { "type": ["string", "null"], "description": "DOI 或文献引用" }
                }
            }
        }
    }
}
